# ─── Kraviona admin panel — environment variables ─────────────────────
# Copy to `.env` (or `.env.local`) and edit. Values are baked into the
# bundle at build/dev time by Vite, so restart `npm run dev` after
# changing them.

# Where the axios client points. Default "/api" works with the
# dev-server proxy below. In a production deploy behind nginx etc.,
# set this to whatever the reverse proxy exposes the API as
# (typically also "/api").
VITE_API_URL=/api

# The dev-server proxy target. Only used by Vite in `npm run dev`;
# ignored in `npm run build`. Defaults to http://localhost:3123
# which is the port kravionatech_backend listens on per its .env.
BACKEND_URL=http://localhost:3123
