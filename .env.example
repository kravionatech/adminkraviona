# Kraviona Admin Panel — environment variables
# Copy this file to `.env` and fill in your values.

# ── REQUIRED ──────────────────────────────────────────────────────────
# The full base URL of the Kraviona backend (with /api suffix).
# Development (default if unset):
#   VITE_API_URL=http://localhost:5000/api
# Production:
#   VITE_API_URL=https://api.kraviona.com/api
VITE_API_URL=http://localhost:5000/api

# ── OPTIONAL ──────────────────────────────────────────────────────────
# Override the default cache TTLs (seconds) used by the public site.
# The admin panel does not use these — they only matter if you embed
# the panel's components on the public site.
# VITE_CACHE_TTL_SERVICES=300
# VITE_CACHE_TTL_SITE_CONFIG=600
# VITE_CACHE_TTL_PORTFOLIO=300
# VITE_CACHE_TTL_TESTIMONIALS=300
# VITE_CACHE_TTL_PRICING=600
